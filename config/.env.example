# cp .env.example .env 후 값을 채우세요. (.env 는 git 에 올리지 않습니다)

# --- Discord ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# background_risk_manager 전용 (없으면 DISCORD_WEBHOOK_URL 사용)
DISCORD_WEBHOOK_URL_RISK=https://discord.com/api/webhooks/...

# --- Naver Search API ---
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# --- OpenAI (선택) ---
OPENAI_API_KEY=

# --- KIS 실전 ---
KIS_MY_APP=
KIS_MY_SEC=
KIS_MY_ACCT_STOCK=
KIS_MY_PROD=01

# --- KIS 모의 (vps / trading_environment=vps 시 사용) ---
KIS_PAPER_APP=
KIS_PAPER_SEC=
KIS_MY_PAPER_STOCK=

# 모의투자 검증 중 금지:
# ASSET_ALLOCATION_ALLOW_PROD=1

# --- KIS 기타 (선택) ---
KIS_MY_HTSID=
# KIS_PROD_URL=   # 기본값 사용 시 비워둠
# KIS_VPS_URL=
# KIS_TOKEN_FILE=/app/output/cache/kis_token.json
# KIS_TOKEN_BACKOFF_SEC=65
# KIS_REAUTH_COOLDOWN_SEC=60
# KIS_TOKEN_LOCK_TIMEOUT_SEC=120
# KIS_HEALTHCHECK_ENV=prod   # health_check.py KIS env

# --- 실행 파라미터 (선택) ---
MARKET=KOSPI
SLOTS=3

# --- Reviewer Git 연동 (선택) ---
# REVIEWER_GIT_REPO=tingcho330/kospistock
# REVIEWER_GIT_BRANCH=main
# REVIEWER_DEPLOY_GRACE_DAYS=3
# REVIEWER_GIT_DISABLED=0
# GITHUB_TOKEN=   # API rate limit 완화 (선택)

# --- 디버그 (선택) ---
DB_RECORD_DEBUG=0
DB_DEBUG_LOG_FILE=/app/output/debug/db_record_debug.log
